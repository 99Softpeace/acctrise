# Database
MONGODB_URI="mongodb+srv://<username>:<password>@<cluster>.mongodb.net/acctrise?retryWrites=true&w=majority"

# Redis
REDIS_URL="redis://localhost:6379"

# Authentication
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-random-secret"
JWT_SECRET="replace-with-random-secret"

# Email Service (Resend)
RESEND_API_KEY=""
AUTH_EMAIL_FROM="Acctrise <no-reply@acctrise.com>"

# Firebase (for push notifications)
FIREBASE_PROJECT_ID=""
FIREBASE_PRIVATE_KEY=""
FIREBASE_CLIENT_EMAIL=""

# Payment Gateways
PAYSTACK_SECRET_KEY=""
PAYSTACK_PUBLIC_KEY=""
FLUTTERWAVE_SECRET_KEY=""
FLUTTERWAVE_PUBLIC_KEY=""
FLUTTERWAVE_WEBHOOK_SECRET=""
POCKETFI_SECRET_KEY=""
POCKETFI_PUBLIC_KEY=""
PAYMENT_FALLBACK_EMAIL="billing@acctrise.com"

# External Providers (NOTE: These should be configured in database with encryption)
# Only shown here for reference - NEVER expose API keys directly
SMM_PROVIDER="reseller-smm"
SMM_PROVIDER_API_KEY=""
LOGS_PROVIDER="bulkacc"
LOGS_PROVIDER_API_KEY=""
NUMBER_PROVIDER="smspool"
NUMBER_PROVIDER_API_KEY=""

# Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Configuration
SERVICE_SYNC_INTERVAL_MINUTES="5" # allowed: 5, 15, 30, 60
WALLET_WEBHOOK_SECRET="replace-with-webhook-secret"
NODE_ENV="development"
LOG_LEVEL="debug"

# For local development only
DEVELOPMENT_USER_ID="test-user-id"

